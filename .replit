modules = ["nodejs-20", "web", "python-3.12", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Gateway"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Service"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client-react && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Gateway"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd gateway-node && node server.js"

[[workflows.workflow]]
name = "AI Service"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ai-python && uvicorn main:app --host 0.0.0.0 --port 8000 --reload"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd ai-python && uvicorn main:app --host 0.0.0.0 --port 8000 & cd gateway-node && node server.js & cd client-react && npx serve dist -l 5000 -s"]
build = ["bash", "-c", "cd client-react && npm install && npm run build && cd ../gateway-node && npm install && pip install fastapi uvicorn pydantic requests"]

[userenv]

[userenv.shared]
AI_SERVICE_URL = "http://localhost:8000"
GATEWAY_PORT = "3001"
NODE_ENV = "development"
